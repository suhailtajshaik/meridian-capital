    { "id": "sec2-label", "type": "text", "x": 418, "y": 798, "width": 325, "height": 55, "text": "🔐 PII never leaves your machine\nanonymizer.py strips merchants/accounts.\nOnly category aggregates sent to LLM.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "strokeColor": "#c92a2a", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "seed": 104 },

