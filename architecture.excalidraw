    { "id": "sec4-label", "type": "text", "x": 58, "y": 883, "width": 325, "height": 55, "text": "☁ Single external egress point\nOnly OpenRouter API call leaves localhost.\nAll financial data stays on-device.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "strokeColor": "#c92a2a", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "seed": 108 },

