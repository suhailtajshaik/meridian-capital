    { "id": "sec5-label", "type": "text", "x": 418, "y": 883, "width": 325, "height": 55, "text": "🆔 Session-scoped isolation\nPer-session SQLite at data/{session_id}.db.\nNo cross-session data leakage.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "strokeColor": "#c92a2a", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "seed": 110 },

