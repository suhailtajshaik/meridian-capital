    { "id": "sec3-label", "type": "text", "x": 778, "y": 798, "width": 325, "height": 55, "text": "🗑 Wipe on demand\nDELETE /api/data/:session_id removes SQLite\nDB, checkpoints & in-memory state.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "strokeColor": "#c92a2a", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "seed": 106 },

