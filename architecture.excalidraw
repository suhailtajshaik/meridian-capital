    { "id": "sec1-label", "type": "text", "x": 58, "y": 798, "width": 325, "height": 55, "text": "🛡 Bind 127.0.0.1 only\nBackend never exposed to LAN/internet.\nCORS locked to http://localhost:5173 only.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "strokeColor": "#c92a2a", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "seed": 102 },

